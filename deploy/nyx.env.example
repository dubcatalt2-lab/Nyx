NODE_ENV=production
PORT=8080
NYX_TRUST_PROXY=true
NYX_SITE_URL=https://example.com
LINK_GENERATOR_PREMIUM_BATCH_LIMIT=10

# WISP_URL is intentionally unset. Nyx serves Wisp itself at /wisp/.
# To enable Nyx AI later, set one of these on the VPS only:
# NYX_AI_API_KEY=replace-with-your-secret
# OPENROUTER_API_KEY=replace-with-your-secret
